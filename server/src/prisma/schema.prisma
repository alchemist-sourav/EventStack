generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  email         String         @unique
  password      String
  role          Role           @default(STUDENT)
  createdAt     DateTime       @default(now())
  registrations Registration[]
}

model Event {
  id            String         @id @default(uuid())
  title         String
  description   String
  speaker       String
  venue         String
  eventDate     DateTime
  seats         Int
  createdAt     DateTime       @default(now())
  registrations Registration[]
}

model Registration {
  id            String   @id @default(uuid())
  fullName      String
  email         String
  phone         String
  department    String
  year          String
  college       String
  createdAt     DateTime @default(now())

  eventId       String
  event         Event    @relation(fields: [eventId], references: [id])

  userId        String
  user          User     @relation(fields: [userId], references: [id])

  @@unique([userId, eventId]) // Prevent duplicate registration by same user for same event
}
